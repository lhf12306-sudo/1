AI_PROVIDER=mock
PORT=3001

# 部署后建议填写你的前端公网地址。
# 多个地址用英文逗号分隔，例如：
# FRONTEND_ORIGIN=http://localhost:5173,https://your-site.vercel.app
FRONTEND_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# 后续启用 openaiProvider 时再设置，不要提交真实密钥：
# OPENAI_API_KEY=your_api_key_here
# OPENAI_MODEL=your_vision_capable_model
